rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // QR code images — publicly readable, only Cloud Functions can write
    match /qr-codes/{fileId} {
      allow read: if true;
      allow write: if false; // Cloud Functions use Admin SDK (bypasses rules)
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
